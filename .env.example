# 方式一：界面配置（推荐）
# 启动后点击右上角「AI 配置」，填入 API Key 并测试连接

# 方式二：环境变量（开发时自动读取）
VITE_OPENAI_API_KEY=sk-your-key-here
VITE_OPENAI_BASE_URL=https://api.deepseek.com/v1
VITE_OPENAI_MODEL=deepseek-chat

